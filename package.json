{
  "name": "@studiolambda/query",
  "version": "1.5.11",
  "description": "Lightweight, isomorphic and framework agnostic asynchronous data management for modern UIs",
  "keywords": [
    "data-management",
    "fetch",
    "isomorphic",
    "query",
    "react",
    "react-query",
    "stale-while-revalidate",
    "swr",
    "ui",
    "vanilla"
  ],
  "homepage": "https://erik.cat/blog/query-docs",
  "license": "MIT",
  "author": {
    "name": "Erik C. Forés",
    "email": "soc@erik.cat",
    "url": "https://erik.cat"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/StudioLambda/Query.git"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/query.cjs",
  "module": "./dist/query.js",
  "types": "./dist/src/query/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/src/query/index.d.ts",
      "import": "./dist/query.js",
      "require": "./dist/query.cjs"
    },
    "./react": {
      "types": "./dist/src/react/index.d.ts",
      "import": "./dist/query_react.js",
      "require": "./dist/query_react.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:only": "vite build",
    "build": "npm run build:only",
    "prebuild": "npm run format:check && npm run lint",
    "lint": "oxlint --deny-warnings",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "dev": "vitest",
    "test": "vitest run",
    "test:ui": "vitest --ui --coverage",
    "test:cover": "vitest run --coverage",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@rolldown/plugin-babel": "^0.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "happy-dom": "^20.8.9",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "picomatch": "^4.0.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.1.1",
    "solid-js": "^1.9.12",
    "typescript": "~5.9.3",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "solid-js": "^1.9.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": ">=11.0.0"
    },
    "runtime": {
      "name": "node",
      "version": ">=24.0.0"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
